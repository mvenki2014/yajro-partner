{
  "name": "react-vite-tailwind",
  "private": true,
  "version": "1.0.5",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "cap:sync": "npm run build && npx cap sync",
    "cap:androido": "npx cap add android && npm run build && npx capacitor-assets generate --android && npx cap sync android && npx cap open android",
    "cap:android": "npm install && npm run build && (npx cap add android || echo 'Android Exists') && npx cap sync android && npx cap open android",
    "cap:ios": "npm run build && npx cap sync ios && npx cap open ios"
  },
